{
  "name": "rasreee.com",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "next build",
    "build:skip-checks": "SKIP_TYPECHECK=true next build --no-lint",
    "clean:build": "rimraf .next",
    "clean:cache": "rimraf .cache",
    "clean:ts": "rimraf ./*.tsbuildinfo",
    "clean": "npm run g:run-s clean:build clean:cache clean:ts",
    "dev": "next dev",
    "fix": "npm run g:run-s \"lint:*:fix\" format:write",
    "format:check": "npm run g:prettier --check",
    "format:write": "npm run g:prettier --write",
    "format": "npm run format:write",
    "install:peerdeps": "npx install --npm",
    "lint:es:fix": "npm run g:eslint --fix",
    "lint:es": "npm run g:eslint",
    "lint:styles:fix": "npm run g:stylelint --fix",
    "lint:styles": "npm run g:stylelint",
    "lint": "npm run g:run-p \"lint:*\" format:check",
    "prepare": "is-ci || husky install",
    "start": "next start",
    "test:changed": "npm run test --changedSince main",
    "test:watch": "npm run test --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "validate": "npm run g:run-s fix typecheck build:skip-checks test",
    "unused-exports": "ts-prune --project tsconfig.json --ignore \"node_modules|.next|.cache|tools|pages|index.ts|jest.config.ts|sanity.cli.ts\" --error",
    "g:eslint": "eslint \"**/*.{js,jsx,ts,tsx}\" --cache --cache-location=.cache/.eslintcache",
    "g:lint-staged": "lint-staged --allow-empty --relative --concurrent false",
    "g:prettier": "prettier \"**/*.{json,md,mdx,yml,yaml}\" --cache --cache-location=.cache/.prettiercache",
    "g:run-p": "run-p --silent --print-label",
    "g:run-s": "run-s --silent --print-label",
    "g:stylelint": "stylelint \"**/*.{css,scss}\" --report-needless-disables --report-invalid-scope-disables --cache --cache-location=.cache/.stylelintcache"
  },
  "dependencies": {
    "@apollo/client": "^3.7.7",
    "@next/font": "13.1.6",
    "@portabletext/react": "^2.0.1",
    "@primer/octicons-react": "^17.11.1",
    "@rasri/log": "^1.3.0",
    "@react-hookz/web": "22.0.0",
    "@sanity/image-url": "^1.0.1",
    "@sanity/vision": "^3.2.1",
    "@tailwindcss/typography": "^0.5.9",
    "@vercel/analytics": "^0.1.8",
    "graphql": "^16.6.0",
    "next": "^13.1.6",
    "next-sanity": "^4.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-loading-skeleton": "^3.1.0",
    "sanity": "^3.2.1",
    "serialize-error": "11.0.0",
    "styled-components": "^5.3.6",
    "swr": "^2.0.3"
  },
  "devDependencies": {
    "@giotramu/stylelint-config": "^11.1.1",
    "@next/bundle-analyzer": "^13.1.6",
    "@next/env": "13.1.6",
    "@next/eslint-plugin-next": "^13.1.6",
    "@swc-node/jest": "^1.5.6",
    "@swc/core": "^1.3.32",
    "@tailwindcss/line-clamp": "0.4.2",
    "@testing-library/jest-dom": "^5.16.5",
    "@types/jest": "^29.4.0",
    "@types/node": "18.11.19",
    "@types/react": "^18.0.27",
    "@types/shell-quote": "^1.7.1",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.33.0",
    "eslint-config-next": "13.1.6",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "husky": "^8.0.3",
    "is-ci": "^3.0.1",
    "jest": "^29.4.1",
    "jest-environment-jsdom": "^29.4.1",
    "lint-staged": "^13.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "postcss-scss": "^4.0.6",
    "prettier": "^2.8.3",
    "prettier-plugin-packagejson": "^2.4.2",
    "prettier-plugin-tailwindcss": "^0.2.2",
    "react-is": "18.2.0",
    "rimraf": "4.1.2",
    "sass": "^1.58.0",
    "shell-quote": "^1.8.0",
    "stylelint": "^14.16.1",
    "stylelint-order": "^6.0.1",
    "tailwindcss": "^3.2.4",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "ts-prune": "^0.10.3",
    "typescript": "^4.9.3"
  },
  "engines": {
    "node": ">=16"
  }
}
