{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "lib": ["esnext"],
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "incremental": true,
    "resolveJsonModule": true,
    "rootDir": "."
  },
  "include": ["**/*.js", "**/*.ts"],
  "exclude": ["**/node_modules", "**/.*/"]
}
